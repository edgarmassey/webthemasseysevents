@page  
@{
    ViewData["Title"] = "Our Home";
}

<div class="py-4">
    <h1>Our Home</h1>
    <p class="text-muted">Our house through time and space.</p>

    <!-- Picture ABOVE the cards -->
    <div class="row mt-3">
        <div class="col-12 d-flex justify-content-center">
            <button type="button"
                    class="p-0 border-0 bg-transparent"
                    data-bs-toggle="modal"
                    data-bs-target="#indexImageModal"
                    data-fullsrc="/Photos/Oldhouse.jpg"
                    aria-label="Open image full size">
                <img src="/Photos/Oldhouse.jpg"
                     alt="Family photo"
                     class="index-footer-image fade-in img-fluid" />
            </button>
        </div>
    </div>


    <!-- Cards BELOW the picture -->
    <div class="row g-4 mt-4">
        <div class="col-md-4">
            <a class="card text-decoration-none h-100 home-menu-card" href="/Home/Historic">
                <div class="card-body">
                    <h5 class="card-title">Historic</h5>
                    <p class="card-text text-muted">Older photos and memories.</p>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a class="card text-decoration-none h-100 home-menu-card" href="/Home/Exterior">
                <div class="card-body">
                    <h5 class="card-title">Exterior</h5>
                    <p class="card-text text-muted">Outside views and changes.</p>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a class="card text-decoration-none h-100 home-menu-card" href="/Home/Interior">
                <div class="card-body">
                    <h5 class="card-title">Interior</h5>
                    <p class="card-text text-muted">Inside rooms and details.</p>
                </div>
            </a>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="indexImageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content bg-transparent border-0">

            <button type="button"
                    class="btn-close btn-close-white position-absolute top-0 end-0 m-3"
                    data-bs-dismiss="modal"
                    aria-label="Close"></button>

            <img id="indexModalImage"
                 src=""
                 class="img-fluid rounded"
                 alt="Family photo" />
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            var img = document.getElementById("indexModalImage");
            if (!img) return;

            document.addEventListener("click", function (e) {
                var btn = e.target.closest('[data-bs-target="#indexImageModal"][data-fullsrc]');
                if (!btn) return;

                img.src = btn.getAttribute("data-fullsrc");
            });
        });
    </script>
}


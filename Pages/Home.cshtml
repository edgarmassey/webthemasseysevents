@page "/Home"
@{
    ViewData["Title"] = "Our Home";
}

<div class="container py-4">
    <h1>Our Home</h1>
    <p class="text-muted">Our house through time and space.</p>

    <div class="row g-4 mt-3">

        <div class="col-md-4">
            <a class="card text-decoration-none h-100" href="/Home/Historic">
                <div class="card-body">
                    <h5 class="card-title">Historic</h5>
                    <p class="card-text text-muted">
                        Older photos and memories.
                    </p>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a class="card text-decoration-none h-100" href="/Home/Exterior">
                <div class="card-body">
                    <h5 class="card-title">Exterior</h5>
                    <p class="card-text text-muted">
                        Outside views and changes.
                    </p>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a class="card text-decoration-none h-100" href="/Home/Interior">
                <div class="card-body">
                    <h5 class="card-title">Interior</h5>
                    <p class="card-text text-muted">
                        Inside rooms and details.
                    </p>
                </div>
            </a>
        </div>

    </div>
</div>

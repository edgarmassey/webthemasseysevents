@page "/Event/{slug}"
@model WebTheMasseysEvents.Pages.EventModel

<div class="container py-4">

    <a href="/events">
        ← Back to Events and pictures
    </a>


    <h1 class="mt-3">@Model.Event!.Title</h1>

    <div class="text-muted">
        @Model.Event!.Date.ToString("yyyy-MM-dd")
        @if (!string.IsNullOrWhiteSpace(Model.Event!.Location))
        {
            <span> • @Model.Event!.Location</span>
        }
    </div>
    
        
    </p>
     
    @* COVER *@
    @if (!string.IsNullOrWhiteSpace(Model.CoverUrl))
    {
        <button type="button"
                class="btn p-0 border-0 mt-3"
                style="background:transparent;"
                data-bs-toggle="modal"
                data-bs-target="#photoModal"
                data-fullsrc="@Model.CoverUrl"
                data-caption="@Model.Event!.Title">
            <img src="@Model.CoverUrl"
                 class="rounded event-cover-img"
                 alt="cover" />

        </button>
    }

    @* Render markdown as HTML so inline image links work *@
    @if (!string.IsNullOrWhiteSpace(Model.Event!.BodyMarkdown))
    {
        <pre class="mt-3" style="white-space:pre-wrap;font-family:inherit">
    @Model.Event!.BodyMarkdown
    </pre>
    }

    @* PHOTO GALLERY *@
    @if (Model.Event!.PhotoFiles.Count > 0)
    {
        <h2 class="h5 mt-4">Photos</h2>

        <div class="row row-cols-2 row-cols-md-4 g-3 mt-1">
            @foreach (var file in Model.Event!.PhotoFiles)
            {
                var fullSrc = $"/Photos/Events/{Model.Event!.Slug}/{file}";

                <div class="col">
                    <button type="button"
                            class="btn p-0 border-0 w-100 text-start"
                            style="background:transparent;"
                            data-bs-toggle="modal"
                            data-bs-target="#photoModal"
                            data-fullsrc="@fullSrc"
                            data-caption="@file">

                        <img src="@fullSrc"
                             class="img-fluid rounded shadow-sm event-thumb-img"
                             alt="photo" />


                        <div class="mt-1 text-muted"
                             style="font-size:0.85rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                            @file.Replace("_", " ").Replace("-", " ").Replace(".jpg", "").Replace(".png", "").Replace(".jpeg", "")
                        </div>
                    </button>
                </div>
            }
        </div>
    }

    @* ONE SINGLE MODAL FOR EVERYTHING *@
    <div class="modal fade" id="photoModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content bg-transparent border-0 position-relative">

                <button type="button"
                        class="btn-close btn-close-white position-absolute top-0 end-0 m-3"
                        style="z-index: 1060; opacity: 1; pointer-events: auto;"
                        data-bs-dismiss="modal"
                        aria-label="Close"></button>

                <button type="button"
                        id="prevPhoto"
                        class="position-absolute top-50 start-0 translate-middle-y ms-2 btn btn-dark rounded-circle"
                        style="z-index:1060;">
                    ‹
                </button>

                <button type="button"
                        id="nextPhoto"
                        class="position-absolute top-50 end-0 translate-middle-y me-2 btn btn-dark rounded-circle"
                        style="z-index:1060;">
                    ›
                </button>

                <div class="modal-body text-center p-0 position-relative">
                    <img id="photoModalImg"
                         class="img-fluid rounded"
                         alt="photo full"
                         style="cursor: zoom-out;"
                         data-bs-dismiss="modal" />

                    <div id="photoModalCaption"
                         style="display:none; position:absolute; left:0; right:0; bottom:0;
                                padding:10px 12px;
                                border-bottom-left-radius:0.5rem; border-bottom-right-radius:0.5rem;
                                background:rgba(0,0,0,0.6);
                                color:#fff;
                                font-size:0.95rem;">
                    </div>
                </div>

            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        (function () {
            const modal = document.getElementById('photoModal');
            const img = document.getElementById('photoModalImg');
            const cap = document.getElementById('photoModalCaption');
            const nextBtn = document.getElementById('nextPhoto');
            const prevBtn = document.getElementById('prevPhoto');

            if (!modal || !img) return;

            function getItems() {
                return Array.from(document.querySelectorAll('[data-fullsrc]'));
            }

            let items = [];
            let index = 0;

            function niceCaption(raw) {
                if (!raw) return "";
                return raw.replace(/[_-]/g, " ").replace(/\.[^/.]+$/, "").trim();
            }

            function showItem(i) {
                if (!items.length) return;

                if (i < 0) i = items.length - 1;
                if (i >= items.length) i = 0;

                index = i;

                const el = items[index];
                const src = el.getAttribute('data-fullsrc');
                const captionRaw = el.getAttribute('data-caption') || "";

                img.src = src;

                if (cap) {
                    const text = niceCaption(captionRaw);
                    cap.textContent = text;
                    cap.style.display = text ? "block" : "none";
                }
            }

            modal.addEventListener('show.bs.modal', function (event) {
                items = getItems();

                let trigger = event.relatedTarget;
                trigger = trigger?.closest?.('[data-fullsrc]') || trigger;

                index = items.indexOf(trigger);
                if (index < 0) index = 0;

                showItem(index);
            });

            nextBtn?.addEventListener('click', (e) => { e.stopPropagation(); showItem(index + 1); });
            prevBtn?.addEventListener('click', (e) => { e.stopPropagation(); showItem(index - 1); });

            document.addEventListener('keydown', function (e) {
                if (!modal.classList.contains('show')) return;

                if (e.key === "ArrowRight") showItem(index + 1);
                if (e.key === "ArrowLeft") showItem(index - 1);
            });

            const swipeTarget = modal.querySelector('.modal-body') || img;

            let startX = 0;
            let startY = 0;
            let tracking = false;

            const SWIPE_MIN_X = 50;
            const SWIPE_MAX_Y = 60;

            swipeTarget.addEventListener('touchstart', function (e) {
                if (!modal.classList.contains('show')) return;

                const t = e.touches[0];
                startX = t.clientX;
                startY = t.clientY;
                tracking = true;
            }, { passive: true });

            swipeTarget.addEventListener('touchmove', function (e) {
                if (!tracking) return;

                const t = e.touches[0];
                const dx = t.clientX - startX;
                const dy = t.clientY - startY;

                if (Math.abs(dx) > 10 && Math.abs(dy) < 10) {
                    e.preventDefault();
                }
            }, { passive: false });

            swipeTarget.addEventListener('touchend', function (e) {
                if (!tracking) return;
                tracking = false;

                const t = e.changedTouches[0];
                const dx = t.clientX - startX;
                const dy = t.clientY - startY;

                if (Math.abs(dy) > SWIPE_MAX_Y) return;

                if (dx <= -SWIPE_MIN_X) showItem(index + 1);
                else if (dx >= SWIPE_MIN_X) showItem(index - 1);
            }, { passive: true });

        })();
    </script>
}

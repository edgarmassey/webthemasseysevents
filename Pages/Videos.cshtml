@page "/videos"
@model WebTheMasseysEvents.Pages.VideosModel

<div class="container py-4">
    <h1>Videos</h1>
    <p class="text-muted">Family videos collection.</p>

    <div class="row g-3 mt-2">
        @foreach (var v in Model.Videos)
        {
            var thumbUrl = $"/Videos/Thumbs/{v.Slug}.png";

            <div class="col-12 col-md-6 col-lg-3">
                <a class="card text-decoration-none h-100 video-card"
                       asp-page="/Video" asp-route-slug="@v.Slug">

                    <div class="video-thumb">
                        <img src="@thumbUrl"
                             alt="@v.Title"
                             loading="lazy" />
                        <span class="video-play">▶</span>
                    </div>

                    <div class="card-body">
                        <h5 class="card-title mb-1">@v.Title</h5>
                        <div class="small text-muted">
                            @v.Date.ToString("yyyy-MM-dd")
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

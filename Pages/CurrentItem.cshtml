@page "/Current/{slug}"
@model WebTheMasseysEvents.Pages.CurrentItemModel

<div class="container py-4">
    <a asp-page="/Current">← Back to Current Things</a>

    @if (Model.Item == null)
    {
        <div class="alert alert-warning mt-3">Not found.</div>
    }
    else
    {
        <h1 class="mt-3">@Model.Item.Title</h1>

        <div class="text-muted mb-3">
            @Model.Item.Date.ToString("yyyy-MM-dd")
        </div>

        @* Optional cover image (thumbnail + click-to-zoom modal) *@
        @if (!string.IsNullOrWhiteSpace(Model.Item.Cover))
        {
            var modalId = "currentCoverModal";

            <button type="button"
                    class="p-0 border-0 bg-transparent"
                    data-bs-toggle="modal"
                    data-bs-target="#@modalId"
                    aria-label="Open image full size">
                <img src="@Model.Item.Cover"
                     class="img-fluid rounded mb-3"
                     style="max-height:260px; width:auto; cursor:pointer;"
                     alt="" />
            </button>

            <div class="modal fade" id="@modalId" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content bg-transparent border-0">
                        <button type="button"
                                class="btn-close btn-close-white ms-auto me-2 mt-2"
                                data-bs-dismiss="modal"
                                aria-label="Close"></button>

                        <img src="@Model.Item.Cover"
                             class="img-fluid rounded"
                             alt="" />
                    </div>
                </div>
            </div>
        }

        <div class="markdown-content">
            @Html.Raw(Model.Item.Html)
        </div>
        @if (Model.Item.GalleryImagesWeb != null && Model.Item.GalleryImagesWeb.Count > 0)
        {
            <hr class="my-4" />
            <h5>Pictures</h5>

            <div class="d-flex flex-wrap gap-2">
                @{
                    int i = 0;
                }
                @foreach (var src in Model.Item.GalleryImagesWeb)
                {
                    i++;
                    <img src="@src"
                         class="rounded gallery-thumb"
                         data-index="@i"
                         style="height:110px;width:110px;object-fit:cover;cursor:pointer;"
                         alt="" />
                }
            </div>

        }

    }
</div>
<div class="modal fade" id="galleryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bg-transparent border-0 position-relative">

            <button type="button"
                    class="btn-close btn-close-white position-absolute end-0 top-0 m-3"
                    data-bs-dismiss="modal"
                    aria-label="Close"></button>

            <button type="button"
                    class="btn btn-light position-absolute start-0 top-50 translate-middle-y"
                    onclick="prevImage()">
                ‹
            </button>

            <img id="galleryModalImage"
                 class="img-fluid rounded d-block mx-auto"
                 style="max-height:80vh;"
                 alt="" />

            <button type="button"
                    class="btn btn-light position-absolute end-0 top-50 translate-middle-y"
                    onclick="nextImage()">
                ›
            </button>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        const galleryImages = @Html.Raw(
                    System.Text.Json.JsonSerializer.Serialize(Model.Item!.GalleryImagesWeb)
            );

        let currentIndex = 0;

        document.querySelectorAll(".gallery-thumb").forEach(img => {
            img.addEventListener("click", () => {
                currentIndex = parseInt(img.dataset.index) - 1;
                showImage();
                new bootstrap.Modal(document.getElementById("galleryModal")).show();
            });
        });

        function showImage() {
            document.getElementById("galleryModalImage").src = galleryImages[currentIndex];
        }

        function nextImage() {
            currentIndex = (currentIndex + 1) % galleryImages.length;
            showImage();
        }

        function prevImage() {
            currentIndex = (currentIndex - 1 + galleryImages.length) % galleryImages.length;
            showImage();
        }
    </script>
}



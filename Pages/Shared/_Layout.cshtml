@using WebTheMasseysEvents.Services
@using System.Text.Json
@inject SiteFlagsService SiteFlags
<!DOCTYPE html>
<html lang="en">

<head>
    <script>
            document.documentElement.classList.add('js');
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebTheMasseysEvents</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" /> 
    <link rel="stylesheet" href="~/WebTheMasseysEvents.styles.css" asp-append-version="true" />
   
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light mb-4 family-navbar">

            <div class="container">

                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    WebTheMasseysEvents
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Current">Current Focus</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/OurKids">Our Kids</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Home">Our Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/events">Events and pictures</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Poetry/Index">English Poetry</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/videos">Videos</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Privacy">Site info</a>
                        </li>
                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <div class="container">
        
        <script>
                    window.SITE_FLAGS = {
                      kidsNewVersion: @Html.Raw(JsonSerializer.Serialize(SiteFlags.KidsNewVersion))
                    };
        </script>
        <script>
                                        @using System.Text.Json
                <script>
                  window.SITE_FLAGS = {
                    kidsNewVersion: @Html.Raw(JsonSerializer.Serialize(SiteFlags.KidsNewVersion))
                  };
</script>
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - WebTheMasseysEvents -
            <a asp-area="" asp-page="/Privacy">Site info</a>

        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
    
</body>
</html>




 @page
@model WebTheMasseysEvents.Pages.IndexModel

<div class="container py-5">

    <!-- Header -->
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">The Massey Family</h1>
        <p class="text-muted">Photos and memories through the years</p>
    </div>

    <!-- Top navigation cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <a asp-page="/Kids" class="text-decoration-none">
                <div class="card shadow-sm h-100 text-center p-4">
                    <h4>👨‍👩‍👧‍👦 Our Kids</h4>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-page="/Home" class="text-decoration-none">
                <div class="card shadow-sm h-100 text-center p-4">
                    <h4>🏡 Our Home</h4>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="/events" class="text-decoration-none">
                <div class="card shadow-sm h-100 text-center p-4">
                    <h4>📅 Events</h4>
                </div>
            </a>
        </div>
    </div>

</div>
